# Local dev: wrangler dev serves the API on port 8787 by default.
PUBLIC_API_URL=http://localhost:8787

# Production: set before `bun run deploy:web` (or copy to .env.production).
# Replace YOUR_SUBDOMAIN with your Cloudflare workers.dev subdomain.
# PUBLIC_API_URL=https://schedule-api.YOUR_SUBDOMAIN.workers.dev
